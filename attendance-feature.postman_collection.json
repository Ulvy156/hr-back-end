    {
      "name": "My Today Attendance",
      "request": {
        "description": "Returns the authenticated employee's attendance for today.\n\nSample response:\n{\n  \"data\": {\n    \"attendanceDate\": \"2026-04-05\",\n    \"todayAttendanceStatus\": \"checked_out\",\n    \"nextAction\": \"none\",\n    \"checkInTime\": \"08:15:00\",\n    \"checkOutTime\": \"17:15:00\",\n    \"workedMinutes\": 480,\n    \"lateMinutes\": 0,\n    \"earlyLeaveMinutes\": 0,\n    \"overtimeMinutes\": 15,\n    \"status\": \"present\",\n    \"source\": \"self_service\",\n    \"correctionStatus\": \"none\",\n    \"notes\": null\n  }\n}",
