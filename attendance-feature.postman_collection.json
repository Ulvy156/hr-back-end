        {
          "name": "Scan Attendance",
          "request": {
            "description": "Authenticated QR scan entry point. Frontend can call this immediately after the printed QR redirects the user into the app.\n\nBehavior:\n- no attendance today -> check in\n- checked in only -> check out\n- already completed today -> reject\n\nSample check-in response:\n{\n  \"message\": \"Check-in recorded successfully.\",\n  \"data\": {\n    \"id\": 42,\n    \"employeeId\": 7,\n    \"attendanceDate\": \"2026-04-05\",\n    \"checkInTime\": \"08:00:00\",\n    \"checkOutTime\": null,\n    \"workedMinutes\": 0,\n    \"status\": \"checked_in\",\n    \"lateMinutes\": 0,\n    \"earlyLeaveMinutes\": 0,\n    \"overtimeMinutes\": 0,\n    \"source\": \"scan\",\n    \"correctionReason\": null,\n    \"correctionStatus\": \"none\"\n  }\n}\n\nSample completed-day validation error:\n{\n  \"message\": \"The given data was invalid.\",\n  \"errors\": {\n    \"attendance\": [\n      \"You have already completed attendance for today.\"\n    ]\n  }\n}",
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/attendance/scan",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "attendance",
                "scan"
              ]
            }
          }
        },
    {
      "name": "Check Out",
      "request": {
        "description": "Employee or HR self-service check-out.\n\nSample success response:\n{\n  \"message\": \"Check-out recorded successfully.\",\n  \"data\": {\n    \"id\": 42,\n    \"employeeId\": 7,\n    \"attendanceDate\": \"2026-04-05\",\n    \"checkInTime\": \"08:15:00\",\n    \"checkOutTime\": \"17:15:00\",\n    \"checkInAt\": \"2026-04-05T08:15:00+07:00\",\n    \"checkOutAt\": \"2026-04-05T17:15:00+07:00\",\n    \"workedMinutes\": 480,\n    \"status\": \"present\",\n    \"lateMinutes\": 0,\n    \"earlyLeaveMinutes\": 0,\n    \"overtimeMinutes\": 15,\n    \"source\": \"self_service\",\n    \"correctionReason\": null,\n    \"correctionStatus\": \"none\"\n  }\n}",
