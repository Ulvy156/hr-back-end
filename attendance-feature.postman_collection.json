    {
      "name": "My Attendance Summary",
      "request": {
        "description": "Returns self-service attendance summary. The `today`, `thisWeek`, and `thisMonth` sections now include overtime minutes.\n\nSample response excerpt:\n{\n  \"data\": {\n    \"today\": {\n      \"workedMinutes\": 540,\n      \"lateMinutes\": 0,\n      \"earlyLeaveMinutes\": 0,\n      \"overtimeMinutes\": 15,\n      \"correctionStatus\": \"none\"\n    },\n    \"thisWeek\": {\n      \"presentDays\": 4,\n      \"lateCount\": 1,\n      \"absentCount\": 0,\n      \"workedMinutes\": 2160,\n      \"overtimeMinutes\": 45\n    },\n    \"thisMonth\": {\n      \"presentDays\": 12,\n      \"lateCount\": 2,\n      \"absentCount\": 1,\n      \"workedMinutes\": 6480,\n      \"overtimeMinutes\": 90,\n      \"pendingCorrectionRequests\": 1\n    }\n  }\n}",
        "method": "GET",
        "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/attendance/me/summary",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "attendance",
                "me",
                "summary"
              ]
            }
          }
        },
        {
      "name": "Submit Correction Request",
      "request": {
        "description": "Submit a correction request for the authenticated employee's own attendance record.\n\nPayload uses a date plus time-only fields.\n\nRules:\n- `request_date` must match an existing attendance record for the authenticated employee.\n- `requested_check_in_time` and `requested_check_out_time` use `HH:MM` format.\n- At least one of the requested time fields is required.\n- If the record already has a pending correction request, the API rejects the new request.\n- If the record was already approved, the API rejects the new request.\n- A new request is allowed again only when the previous correction request was rejected.\n\nSample success response:\n{\n  \"message\": \"Attendance correction request submitted successfully.\",\n  \"data\": {\n    \"id\": 15,\n    \"attendanceId\": 42,\n    \"attendanceDate\": \"2026-04-03\",\n    \"requestDate\": \"2026-04-03\",\n    \"employee\": {\n      \"id\": 7,\n      \"name\": \"Emma Employee\",\n      \"department\": \"Operations\"\n    },\n    \"requestedCheckInTime\": \"08:00\",\n    \"requestedCheckOutTime\": \"17:00\",\n    \"reason\": \"Scanner was delayed during entry.\",\n    \"status\": \"pending\",\n    \"reviewNote\": null,\n    \"reviewedAt\": null,\n    \"reviewedBy\": null,\n    \"createdAt\": \"2026-04-05T09:00:00+07:00\",\n    \"updatedAt\": \"2026-04-05T09:00:00+07:00\",\n    \"attendance\": null\n  }\n}\n\nSample validation error for an already approved attendance record:\n{\n  \"message\": \"The given data was invalid.\",\n  \"errors\": {\n    \"request_date\": [\n      \"This attendance record has already been corrected and approved. A new correction request is only allowed after rejection.\"\n    ]\n  }\n}",
        "method": "POST",
        "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_date\": \"2026-04-03\",\n  \"requested_check_in_time\": \"08:00\",\n  \"requested_check_out_time\": \"17:00\",\n  \"reason\": \"Scanner was delayed during entry.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendance/me/correction-request",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "attendance",
                "me",
                "correction-request"
              ]
            }
          }
        },
        {
          "name": "Submit Missing Attendance Request",
          "request": {
            "description": "Submit a missing attendance request for a date where the authenticated employee has no attendance record yet.\n\nRules:\n- Use this when the employee forgot both check-in and check-out.\n- `request_date` identifies the attendance day.\n- `requested_check_in_time` and `requested_check_out_time` use `HH:MM` format.\n- At least one of the requested time fields is required.\n- The API rejects the request if an attendance record already exists for that date.\n- A new missing request for the same date is blocked while a previous one is pending or already approved.\n- A new request is allowed again only when the previous missing request was rejected.\n\nSample success response:\n{\n  \"message\": \"Missing attendance request submitted successfully.\",\n  \"data\": {\n    \"id\": 16,\n    \"attendanceId\": null,\n    \"attendanceDate\": \"2026-04-04\",\n    \"requestDate\": \"2026-04-04\",\n    \"employee\": {\n      \"id\": 7,\n      \"name\": \"Emma Employee\",\n      \"department\": \"Operations\"\n    },\n    \"requestedCheckInTime\": \"08:00\",\n    \"requestedCheckOutTime\": \"17:00\",\n    \"reason\": \"I forgot to check in and check out that day.\",\n    \"status\": \"pending\",\n    \"reviewNote\": null,\n    \"reviewedAt\": null,\n    \"reviewedBy\": null,\n    \"createdAt\": \"2026-04-05T09:00:00+07:00\",\n    \"updatedAt\": \"2026-04-05T09:00:00+07:00\",\n    \"attendance\": null\n  }\n}\n\nSample validation error for a duplicate approved/pending request:\n{\n  \"message\": \"The given data was invalid.\",\n  \"errors\": {\n    \"request_date\": [\n      \"A missing attendance request for this date already exists and can only be submitted again after rejection.\"\n    ]\n  }\n}",
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_date\": \"2026-04-04\",\n  \"requested_check_in_time\": \"08:00\",\n  \"requested_check_out_time\": \"17:00\",\n  \"reason\": \"I forgot to check in and check out that day.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendance/me/missing-request",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "attendance",
                "me",
                "missing-request"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Attendance HR",
      "item": [
    {
      "name": "Attendance List",
      "request": {
        "description": "HR/admin attendance management list.\n\nSample item excerpt:\n{\n  \"id\": 42,\n  \"employeeId\": 7,\n  \"attendanceDate\": \"2026-04-05\",\n  \"checkInTime\": \"08:15:00\",\n  \"checkOutTime\": \"17:15:00\",\n  \"workedMinutes\": 540,\n  \"status\": \"present\",\n  \"lateMinutes\": 0,\n  \"earlyLeaveMinutes\": 0,\n  \"overtimeMinutes\": 15,\n  \"source\": \"manual\",\n  \"correctionStatus\": \"none\",\n  \"employee\": {\n    \"id\": 7,\n    \"name\": \"Emma Employee\",\n    \"department\": \"Operations\"\n  }\n}",
        "method": "GET",
        "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/attendance?employee_id={{employee_id}}&department_id={{department_id}}&status=present&from_date=2026-04-01&to_date=2026-04-30&per_page=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "attendance"
              ],
              "query": [
                {
                  "key": "employee_id",
                  "value": "{{employee_id}}"
                },
                {
