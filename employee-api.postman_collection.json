        {
          "name": "Create",
          "request": {
            "description": "Create a new employee and optionally store all related employee info in one request: structured addresses, emergency contacts, educations, and employee position history.\n\nSample success response:\n{\n  \"id\": 12,\n  \"user_id\": 2,\n  \"employee_code\": \"EMP000012\",\n  \"first_name\": \"Dara\",\n  \"last_name\": \"Lim\",\n  \"full_name\": \"Dara Lim\",\n  \"email\": \"dara.lim@example.com\",\n  \"phone\": \"010222333\",\n  \"hire_date\": \"2026-04-01\",\n  \"status\": \"active\",\n  \"branch\": { \"id\": 1, \"name\": \"HQ\", \"code\": \"HQ\" },\n  \"shift\": { \"id\": 1, \"name\": \"Day Shift\", \"code\": \"DAY\", \"start_time\": \"08:00:00\", \"end_time\": \"17:00:00\", \"late_grace_minutes\": 0 },\n  \"current_position\": { \"id\": 1, \"title\": \"Support Agent\" },\n  \"addresses\": [\n    {\n      \"id\": 1,\n      \"address_type\": \"current\",\n      \"province_id\": 1,\n      \"district_id\": 1,\n      \"commune_id\": 1,\n      \"village_id\": 1,\n      \"address_line\": \"Apartment 10B\",\n      \"street\": \"Street 271\",\n      \"house_no\": \"10B\",\n      \"postal_code\": \"12000\",\n      \"note\": \"Near the market\",\n      \"is_primary\": true,\n      \"province\": { \"id\": 1, \"code\": \"01\", \"name_kh\": \"ភ្នំពេញ\", \"name_en\": \"Phnom Penh\" },\n      \"district\": { \"id\": 1, \"code\": \"101\", \"name_kh\": \"ចំការមន\", \"name_en\": \"Chamkar Mon\", \"type\": \"ក្រុង\" },\n      \"commune\": { \"id\": 1, \"code\": \"10101\", \"name_kh\": \"ទន្លេបាសាក់\", \"name_en\": \"Tonle Basak\" },\n      \"village\": { \"id\": 1, \"code\": \"1010101\", \"name_kh\": \"ភូមិ១\", \"name_en\": \"Village 1\" }\n    }\n  ],\n  \"educations\": [\n    {\n      \"id\": 3,\n      \"institution_name\": \"Royal University of Phnom Penh\",\n      \"education_level\": \"bachelor\",\n      \"degree\": \"Bachelor of Management\"\n    }\n  ],\n  \"employee_positions\": [\n    {\n      \"id\": 9,\n      \"position_id\": 1,\n      \"position\": { \"id\": 1, \"title\": \"Support Agent\" },\n      \"base_salary\": \"600.00\",\n      \"start_date\": \"2026-04-01\",\n      \"end_date\": null,\n      \"is_current\": true\n    }\n  ],\n  \"emergency_contacts\": [\n    {\n      \"id\": 1,\n      \"name\": \"Primary Contact\",\n      \"relationship\": \"spouse\",\n      \"phone\": \"011111111\",\n      \"email\": \"primary@example.com\",\n      \"is_primary\": true\n    }\n  ]\n}",
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{user_id}},\n  \"department_id\": {{department_id}},\n  \"branch_id\": {{branch_id}},\n  \"current_position_id\": {{current_position_id}},\n  \"shift_id\": {{shift_id}},\n  \"manager_id\": {{manager_id}},\n  \"first_name\": \"Dara\",\n  \"last_name\": \"Lim\",\n  \"email\": \"dara.lim@example.com\",\n  \"phone\": \"010222333\",\n  \"date_of_birth\": \"1995-11-02\",\n  \"gender\": \"female\",\n  \"personal_phone\": \"099555666\",\n  \"personal_email\": \"dara.personal@example.com\",\n  \"addresses\": [\n    {\n      \"address_type\": \"current\",\n      \"province_id\": {{province_id}},\n      \"district_id\": {{district_id}},\n      \"commune_id\": {{commune_id}},\n      \"village_id\": {{village_id}},\n      \"address_line\": \"Apartment 10B\",\n      \"street\": \"Street 271\",\n      \"house_no\": \"10B\",\n      \"postal_code\": \"12000\",\n      \"note\": \"Near the market\",\n      \"is_primary\": true\n    },\n    {\n      \"address_type\": \"permanent\",\n      \"address_line\": \"Family home\",\n      \"street\": \"National Road 6\",\n      \"house_no\": \"22A\",\n      \"postal_code\": \"13000\"\n    }\n  ],\n  \"id_type\": \"national_id\",\n  \"id_number\": \"ID-2026-001\",\n  \"emergency_contact_name\": \"Legacy Contact\",\n  \"emergency_contact_relationship\": \"sibling\",\n  \"emergency_contact_phone\": \"012999999\",\n  \"hire_date\": \"2026-04-01\",\n  \"employment_type\": \"full_time\",\n  \"confirmation_date\": \"2026-07-01\",\n  \"status\": \"active\",\n  \"include\": [\"addresses\", \"emergency_contacts\", \"educations\", \"employee_positions\"],\n  \"emergency_contacts\": [\n    {\n      \"name\": \"Primary Contact\",\n      \"relationship\": \"spouse\",\n      \"phone\": \"011111111\",\n      \"email\": \"primary@example.com\",\n      \"is_primary\": true\n    },\n    {\n      \"name\": \"Second Contact\",\n      \"relationship\": \"parent\",\n      \"phone\": \"022222222\"\n    }\n  ],\n  \"educations\": [\n    {\n      \"institution_name\": \"Royal University of Phnom Penh\",\n      \"education_level\": \"bachelor\",\n      \"degree\": \"Bachelor of Management\",\n      \"field_of_study\": \"Management\",\n      \"graduation_year\": 2022\n    }\n  ],\n  \"employee_positions\": [\n    {\n      \"position_id\": {{current_position_id}},\n      \"base_salary\": 600,\n      \"start_date\": \"2026-04-01\",\n      \"end_date\": null\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/employees",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees"
              ]
            }
          }
        },
        {
          "name": "Show",
          "request": {
            "description": "Show a single employee. Employee role can view only their own employee record.\n\nSample response includes optional relations via include=addresses,educations,emergency_contacts,employee_positions,user.",
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/employees/{{employee_id}}?include=addresses,educations,emergency_contacts,employee_positions,user",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees",
                "{{employee_id}}"
              ],
              "query": [
                {
                  "key": "include",
                  "value": "addresses,educations,emergency_contacts,employee_positions,user"
                }
              ]
            }
          }
        },
        {
          "name": "Employee Addresses",
          "item": [
            {
              "name": "List Addresses",
              "request": {
                "description": "List employee addresses independently from the main employee update API.",
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/employees/{{employee_id}}/addresses",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "employees",
                    "{{employee_id}}",
                    "addresses"
                  ]
                }
              }
            },
            {
              "name": "Create Address",
              "request": {
                "description": "Create one employee address independently.",
                "method": "POST",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"address_type\": \"current\",\n  \"province_id\": {{province_id}},\n  \"district_id\": {{district_id}},\n  \"commune_id\": {{commune_id}},\n  \"village_id\": {{village_id}},\n  \"address_line\": \"Apartment 10B\",\n  \"street\": \"Street 271\",\n  \"house_no\": \"10B\",\n  \"postal_code\": \"12000\",\n  \"note\": \"Near the market\",\n  \"is_primary\": true\n}"
                },
                "url": {
                  "raw": "{{base_url}}/employees/{{employee_id}}/addresses",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "employees",
                    "{{employee_id}}",
                    "addresses"
                  ]
                }
              }
            },
            {
              "name": "Update Address",
              "request": {
                "description": "Update one employee address independently.",
                "method": "PUT",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
