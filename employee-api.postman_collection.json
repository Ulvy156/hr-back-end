        {
          "name": "List",
          "request": {
            "description": "List employees with pagination.\n\nSample response:\n{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"employee_code\": \"EMP000001\",\n      \"first_name\": \"Emma\",\n      \"last_name\": \"Employee\",\n      \"full_name\": \"Emma Employee\",\n      \"email\": \"emma.employee@example.com\",\n      \"phone\": \"012345678\",\n      \"profile_photo\": null,\n      \"profile_photo_path\": null,\n      \"hire_date\": \"2026-04-01\",\n      \"employment_type\": \"full_time\",\n      \"status\": \"active\",\n      \"department\": { \"id\": 1, \"name\": \"Operations\" },\n      \"current_position\": { \"id\": 1, \"title\": \"Officer\" },\n      \"position\": { \"id\": 1, \"title\": \"Officer\" },\n      \"manager\": { \"id\": 2, \"name\": \"Helen HR\" },\n      \"branch\": { \"id\": 1, \"name\": \"HQ\", \"code\": \"HQ\" },\n      \"shift\": { \"id\": 1, \"name\": \"Morning\", \"code\": \"MORNING\", \"start_time\": \"08:00:00\", \"end_time\": \"17:00:00\", \"late_grace_minutes\": 0 },\n      \"created_at\": \"2026-04-05T10:00:00+07:00\",\n      \"updated_at\": \"2026-04-05T10:00:00+07:00\",\n      \"deleted_at\": null\n    }\n  ],\n  \"links\": {},\n  \"meta\": {}\n}",
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/employees?page=1&per_page=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Filtered List",
          "request": {
            "description": "Filter employees by search, status, org structure, employment type, hire date, sorting, and includes.\n\nSample query:\nsearch=Emma&status=active&department_id=1&branch_id=1&current_position_id=1&manager_id=2&employment_type=full_time&hire_date_from=2026-04-01&hire_date_to=2026-04-30&sort_by=first_name&sort_direction=asc&include=addresses,educations,emergency_contacts,employee_positions",
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/employees?search=Emma&status=active&department_id={{department_id}}&branch_id={{branch_id}}&current_position_id={{current_position_id}}&manager_id={{manager_id}}&employment_type=full_time&hire_date_from=2026-04-01&hire_date_to=2026-04-30&sort_by=first_name&sort_direction=asc&per_page=20&include=addresses,educations,emergency_contacts,employee_positions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "Emma"
                },
                {
                  "key": "status",
                  "value": "active"
                },
                {
                  "key": "department_id",
                  "value": "{{department_id}}"
                },
                {
                  "key": "branch_id",
                  "value": "{{branch_id}}"
                },
                {
                  "key": "current_position_id",
                  "value": "{{current_position_id}}"
                },
                {
                  "key": "manager_id",
                  "value": "{{manager_id}}"
                },
                {
                  "key": "employment_type",
                  "value": "full_time"
                },
                {
                  "key": "hire_date_from",
                  "value": "2026-04-01"
                },
                {
                  "key": "hire_date_to",
                  "value": "2026-04-30"
                },
                {
                  "key": "sort_by",
                  "value": "first_name"
                },
                {
                  "key": "sort_direction",
                  "value": "asc"
                },
                {
                  "key": "per_page",
                  "value": "20"
                },
                {
                  "key": "include",
                  "value": "addresses,educations,emergency_contacts,employee_positions"
                }
              ]
            }
          }
        },
        {
          "name": "Export Employees",
          "request": {
            "description": "Download an Excel export of employees. HR only.\n\nThis uses the same filters as the employee list API and returns an .xlsx file download.\n\nExported columns:\n- Employee Code\n- Full Name\n- Email\n- Phone\n- Department\n- Current Position\n- Manager\n- Hire Date\n- Employment Type\n- Status",
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
              }
            ],
            "url": {
              "raw": "{{base_url}}/employees/export/excel",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees",
                "export",
                "excel"
              ]
            }
          }
        },
