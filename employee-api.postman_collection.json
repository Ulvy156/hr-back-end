              }
            ],
            "url": {
              "raw": "{{base_url}}/locations/provinces?search=phnom",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "locations",
                "provinces"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "phnom"
                }
              ]
            }
          }
        },
