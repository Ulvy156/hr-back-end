    {
      "key": "keyword",
      "value": ""
    },
    {
      "key": "log_name",
      "value": "attendance"
    },
    {
      "key": "event",
      "value": "check_in"
    },
    {
      "key": "causer_id",
      "value": "1"
    },
    {
      "key": "subject_type",
      "value": "App\\\\Models\\\\Attendance"
    },
    {
      "key": "subject_id",
      "value": "1"
    },
    {
      "key": "from_date",
      "value": "2026-04-01"
    },
    {
      "key": "to_date",
      "value": "2026-04-30"
