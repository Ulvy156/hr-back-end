                "export",
                "excel"
              ],
              "query": [
                {
                  "key": "keyword",
                  "value": "{{keyword}}"
                },
                {
                  "key": "log_name",
                  "value": "{{log_name}}"
                },
                {
                  "key": "event",
                  "value": "{{event}}"
                },
                {
                  "key": "causer_id",
                  "value": "{{causer_id}}"
                },
                {
                  "key": "subject_type",
                  "value": "{{subject_type}}"
                },
                {
                  "key": "subject_id",
